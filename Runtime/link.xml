<linker>
    <!-- Prevent IL2CPP code stripping for Newtonsoft.Json -->
    <assembly fullname="Newtonsoft.Json" preserve="all"/>
    <!-- Preserve Ovation models for JSON deserialization -->
    <assembly fullname="Ovation.Runtime" preserve="all">
        <type fullname="Ovation.Models.*" preserve="all"/>
    </assembly>
</linker>
